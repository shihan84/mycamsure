// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  TECHNICIAN
  FRANCHISEE
  ADMIN
}

enum ServiceType {
  INSTALLATION
  REPAIR
  MAINTENANCE
  AMC_VISIT
}

enum ServiceStatus {
  PENDING
  ASSIGNED
  TECHNICIAN_EN_ROUTE
  TECHNICIAN_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AMCPlanType {
  QUARTERLY
  YEARLY
}

enum AMCStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TechnicianVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum FranchiseStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

model User {
  id            String       @id @default(uuid())
  firebaseUid   String?      @unique
  name          String
  email         String?      @unique
  phone         String       @unique
  role          UserRole     @default(CUSTOMER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  franchise     Franchise?
  technician    Technician?
  serviceRequestsAsCustomer  ServiceRequest[] @relation("CustomerServiceRequests")
  serviceRequestsAsTechnician ServiceRequest[] @relation("TechnicianServiceRequests")
  notifications Notification[]
  payments      PaymentTransaction[]
  reviews       Review[]
  amcContracts  AMCContract[]
  earnings      Earnings[]
  paymentTransactions PaymentTransaction[]

  @@map("users")
}

model Franchise {
  id            String            @id @default(uuid())
  name          String
  ownerId       String            @unique
  commissionRate Float            @default(15.0) // percentage
  status        FranchiseStatus   @default(PENDING)
  region        String?
  city          String?
  state         String?
  pincode       String?
  address       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  owner         User              @relation(fields: [ownerId], references: [id])
  technicians   Technician[]
  serviceRequests ServiceRequest[]
  amcContracts  AMCContract[]

  @@map("franchises")
}

model Technician {
  id                String                      @id @default(uuid())
  userId            String                      @unique
  franchiseId       String?
  isVerified        TechnicianVerificationStatus @default(PENDING)
  rating            Float                       @default(0.0)
  totalJobs         Int                         @default(0)
  locationLat       Float?
  locationLng       Float?
  currentJobId      String?
  available         Boolean                     @default(true)
  documents         Json? // Store document URLs and verification status
  skills            String[] // e.g., ["CCTV", "Alarm", "Access Control"]
  experience        Int? // years
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  // Relations
  user              User                        @relation(fields: [userId], references: [id])
  franchise         Franchise?                  @relation(fields: [franchiseId], references: [id])
  serviceRequests   ServiceRequest[]
  earnings          Earnings[]

  @@map("technicians")
}

model ServiceRequest {
  id              String        @id @default(uuid())
  customerId      String
  technicianId    String?
  franchiseId     String?
  type            ServiceType
  status          ServiceStatus @default(PENDING)
  scheduledAt     DateTime
  address         String
  latitude        Float?
  longitude       Float?
  description     String?
  photos          Json? // Array of photo URLs
  totalAmount     Float
  commissionAmount Float? // Franchise commission
  technicianAmount Float? // Technician payout
  estimatedDuration Int? // in minutes
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  customer        User          @relation("CustomerServiceRequests", fields: [customerId], references: [id])
  technician      User?         @relation("TechnicianJobs", fields: [technicianId], references: [id])
  franchise       Franchise?    @relation(fields: [franchiseId], references: [id])
  amcContract     AMCContract?
  paymentTransaction PaymentTransaction?
  review          Review?

  @@map("service_requests")
}

model AMCContract {
  id              String      @id @default(uuid())
  customerId      String
  franchiseId     String
  startDate       DateTime
  endDate         DateTime
  planType        AMCPlanType
  price           Float
  status          AMCStatus   @default(ACTIVE)
  totalVisits     Int         @default(0)
  visitsUsed      Int         @default(0)
  renewalCount    Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  customer        User        @relation(fields: [customerId], references: [id])
  franchise       Franchise   @relation(fields: [franchiseId], references: [id])
  serviceRequests ServiceRequest[]

  @@map("amc_contracts")
}

model PaymentTransaction {
  id                  String        @id @default(uuid())
  serviceRequestId    String?       @unique
  amcContractId       String?
  userId              String
  amount              Float
  status              PaymentStatus @default(PENDING)
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?
  stripePaymentIntentId String?
  paymentMethod       String? // "online", "cash", "upi"
  franchiseShare      Float? // Amount going to franchise
  adminShare          Float? // Platform commission
  technicianShare     Float? // Amount going to technician
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  serviceRequest      ServiceRequest? @relation(fields: [serviceRequestId], references: [id])
  user                User          @relation(fields: [userId], references: [id])

  @@map("payment_transactions")
}

model Review {
  id              String    @id @default(uuid())
  serviceRequestId String   @unique
  customerId      String
  rating          Int      // 1-5
  comment         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  serviceRequest  ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  customer        User          @relation(fields: [customerId], references: [id])

  @@map("reviews")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  type        String? // "job_assigned", "job_status", "payment", "system"
  isRead      Boolean  @default(false)
  data        Json? // Additional data
  createdAt   DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Earnings {
  id              String    @id @default(uuid())
  technicianId    String
  amount          Float
  jobId           String?
  type            String    // "service", "bonus", "penalty"
  status          String    @default("pending") // "pending", "withdrawn"
  createdAt       DateTime  @default(now())
  withdrawnAt     DateTime?

  // Relations
  technician      Technician @relation(fields: [technicianId], references: [id])

  @@map("earnings")
}
